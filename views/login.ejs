                        <h3 style="text-align: center;">Password</h3>
                        <input type="password" class="form-control" style="width: 100%; margin-bottom: 10px;"
                            name="password">
                        <button type="submit" class="btn btn-primary login-btn"
                            style="margin-left: 150px; margin-top: 20px; margin-bottom: 10px;">Login</button>
                    </form>
                </div>
            </div>
            <div class="col-lg-4">
            </div>
        </div>
        <div>
            <button type="submit" class="btn btn-primary login-btn"
                style="position: relative; left:375px; margin-top: 10px;"><a href="/create" style="color:white">Create
                    Account</a></button>
            <button type="text" class="btn btn-primary" style="position: relative; left:475px; margin-top: 10px;"><a
                    href="/home" style="color:white">Continue without Login</a></button>
        </div>
