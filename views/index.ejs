<!DOCTYPE html>
<html lang="en" dir="ltr">

<head>
    <meta charset="utf-8">
    <title>Sleep Monitor</title>
    <meta charset="utf-8">
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/styles.css">
    <nav class="navbar navbar-default" style="background-color: rgb(112, 112, 112);">
        <div class="container">
            <div class="navbar-header">
                <p class="navbar-brand" style="color: #1abc9c;font-size: 25px;">SLEEP MONITOR</p>
            </div>
            <ul class="nav navbar-nav navbar-right">
                <li id="home"><a href="/" style="color:rgb(224, 221, 221);">HOME</a></li>
                <li id="about"><a href="/about" style="color:rgb(224, 221, 221);">ABOUT</a></li>
                <li id="contacts"><a href="/contacts" style="color:rgb(224, 221, 221);">CONTACT</a></li>
            </ul>
        </div>
    </nav>
</head>

<body>
    <div class="container">
        <br>
        <image src="https://elsnerlawfirm.com/wp-content/uploads/2016/12/DrowsyDriving-1024x642.png" style="position: absolute;left: 0px; width: 50%; padding-top: 40px;"></image>
        <div class="row" style="padding-bottom: 300px;">
            <div class="col-lg-6 col-md-12">
            </div>
            <div class="col-lg-6 col-md-12" style="text-align: right;">
                <h1 style="color:#222222; font-size:75px;">Overview</h1>
                <br>
                <h3 style="color: #222222;letter-spacing: 2px; font-size: 35px;">
                    This WebApp is designed to prevent accidents which are caused due to DROWSY DRIVING.   
                </h3>
            </div>
        </div>
        <br>
        <div class="row">
            <div style="text-align: center;">
                <h1 style="color:#222222; margin-left: auto; margin-right:auto; font-size: 50px;">Features</h1>
                <br>
                <div class="col-lg-4 col-md-12">
                    <h1>Sleep monitoring</h1>
                </div>
                <div class="col-lg-4 col-md-12">
                    <h1>Sirens</h1>
                </div>
                <div class="col-lg-4 col-md-12">
                    <h1>Emergency emails to contact</h1>
                </div>
            </div>
        </div>
        <br>
        <div class="col-lg-12 text-center">
            <button type="text" class="btn btn-primary"><a href="/login" style="color: white;" class="loginpage">
                    <%=loggedIn%>
                </a></button>
            <br>
            <br>
            <button type="text" class="btn btn-primary"><a href="/home" style="color: white;">
                   Start
                </a></button>
        </div>
    </div>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script>
        var status = $(".loginpage").text();
        console.log(status);
        if (status === "Login") {
            $(".loginpage").attr("href", "/login");
        } else {
            $(".loginpage").attr("href", "/logout");
        }

    </script>
</body>

<footer>
    <div class="footer-padding"></div>
    <div class="footer">
        <p>Made by Sriyans</p>
    </div>>
</footer>

</html>